// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(cuid())
  fullName     String
  email        String         @unique
  passwordHash String
  avatarUrl    String?
  phone        String?
  dateOfBirth     String?
  graduationYear  Int?
  
  // About Me
  headline     String?
  bio          String?
  
  // Professional Info
  occupation   String?
  company      String?
  position     String?
  
  // Location
  city         String?
  province     String?
  country      String?
  
  // Social Media
  linkedin     String?
  instagram    String?
  facebook     String?
  website      String?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  servers      Server[]       @relation("ServerOwner")
  memberships  ServerMember[]
  messages     Message[]
  media        MemoryMedia[]
}

model Server {
  id             String         @id @default(cuid())
  serverCode     String         @unique
  schoolName     String
  graduationYear Int
  description    String?
  ownerId        String
  owner          User           @relation("ServerOwner", fields: [ownerId], references: [id])
  createdAt      DateTime       @default(now())
  members        ServerMember[]
  messages       Message[]
  contacts       AlumniContact[]
  media          MemoryMedia[]
  adminCodes     ArchiveAdminCode[]
  announcements  Announcement[]
  events         Event[]
}

model ServerMember {
  id       String   @id @default(cuid())
  serverId String
  userId   String
  joinedAt DateTime @default(now())
  server   Server   @relation(fields: [serverId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([serverId, userId])
}

model Message {
  id        String   @id @default(cuid())
  serverId  String
  userId    String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  edited    Boolean  @default(false)
  isDeleted Boolean  @default(false)
  
  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[] @relation("MessageReplies")

  server    Server   @relation(fields: [serverId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model AlumniContact {
  id             String @id @default(cuid())
  serverId       String
  fullName       String
  graduationYear Int
  phone          String?
  email          String?
  address        String?
  occupation     String?
  company        String?
  server         Server @relation(fields: [serverId], references: [id])
}

model MemoryMedia {
  id        String   @id @default(cuid())
  serverId  String
  title     String
  mediaUrl  String
  mediaType String // e.g., "image", "video", "document"
  uploadedBy String
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id])
  user      User     @relation(fields: [uploadedBy], references: [id])
}

model ArchiveAdminCode {
  id        String   @id @default(cuid())
  serverId  String
  codeHash  String
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  serverId  String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  server    Server   @relation(fields: [serverId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  serverId    String
  title       String
  description String
  eventDate   DateTime
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  server      Server   @relation(fields: [serverId], references: [id])
}

