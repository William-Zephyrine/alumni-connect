generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  fullName       String
  email          String         @unique
  passwordHash   String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  avatarUrl      String?
  city           String?
  company        String?
  country        String?
  facebook       String?
  graduationYear Int?
  instagram      String?
  linkedin       String?
  occupation     String?
  phone          String?
  position       String?
  province       String?
  website        String?
  bio            String?
  dateOfBirth    String?
  headline       String?
  media          MemoryMedia[]
  messages       Message[]
  servers        Server[]       @relation("ServerOwner")
  memberships    ServerMember[]
}

model Server {
  id             String             @id @default(cuid())
  serverCode     String             @unique
  schoolName     String
  graduationYear Int
  description    String?
  ownerId        String
  createdAt      DateTime           @default(now())
  contacts       AlumniContact[]
  announcements  Announcement[]
  adminCodes     ArchiveAdminCode[]
  events         Event[]
  media          MemoryMedia[]
  messages       Message[]
  owner          User               @relation("ServerOwner", fields: [ownerId], references: [id])
  members        ServerMember[]
}

model ServerMember {
  id       String   @id @default(cuid())
  serverId String
  userId   String
  joinedAt DateTime @default(now())
  server   Server   @relation(fields: [serverId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([serverId, userId])
}

model Message {
  id        String    @id @default(cuid())
  serverId  String
  userId    String
  message   String
  createdAt DateTime  @default(now())
  edited    Boolean   @default(false)
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[] @relation("MessageReplies")
  server    Server    @relation(fields: [serverId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model AlumniContact {
  id             String  @id @default(cuid())
  serverId       String
  fullName       String
  graduationYear Int
  phone          String?
  email          String?
  address        String?
  occupation     String?
  company        String?
  server         Server  @relation(fields: [serverId], references: [id])
}

model MemoryMedia {
  id         String   @id @default(cuid())
  serverId   String
  title      String
  mediaUrl   String
  mediaType  String
  uploadedBy String
  createdAt  DateTime @default(now())
  server     Server   @relation(fields: [serverId], references: [id])
  user       User     @relation(fields: [uploadedBy], references: [id])
}

model ArchiveAdminCode {
  id        String   @id @default(cuid())
  serverId  String
  codeHash  String
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  serverId  String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  server    Server   @relation(fields: [serverId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  serverId    String
  title       String
  description String
  eventDate   DateTime
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  server      Server   @relation(fields: [serverId], references: [id])
}
